# Microsoft Entra ID (Azure AD) app registration
TENANT_ID=your-tenant-id-or-domain.onmicrosoft.com
CLIENT_ID=00000000-0000-0000-0000-000000000000

# The shared mailbox to monitor (UPN, e.g. support@erc.ph)
SHARED_MAILBOX=shared@erc.ph

# How often to poll Microsoft Graph for new messages (seconds)
POLL_INTERVAL_SECONDS=60

# Where to store the SQLite database
DB_PATH=./emailtracker.db

# Where to persist the MSAL token cache (keep out of version control)
TOKEN_CACHE_PATH=./.token_cache.json

# Web server bind address
WEB_HOST=127.0.0.1
WEB_PORT=8000
