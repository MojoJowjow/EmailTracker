# The shared mailbox to monitor. Must be the PRIMARY SMTP address as it appears
# to Outlook (e.g. support@erc.ph). You must already have Read access in Outlook.
SHARED_MAILBOX=shared@erc.ph

# How often to check Outlook for new messages (seconds)
POLL_INTERVAL_SECONDS=60

# On first run, how many days of history to import from the shared mailbox.
# Subsequent runs only pick up new messages since the last successful sync.
INITIAL_SYNC_DAYS=30

# Where to store the SQLite database
DB_PATH=./emailtracker.db

# Web server bind address
WEB_HOST=127.0.0.1
WEB_PORT=8000
